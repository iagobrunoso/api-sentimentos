name: CI/CD Pipeline

on:
  pull_request:
    types: [closed]

jobs:
  build:
    if: github.event.pull_request.merged == true
    runs-on: ubuntu-latest

    steps:
      - name: Checkout código
        uses: actions/checkout@v3

      - name: Build Docker
        run: docker build -t api-sentimentos .

      - name: Login Docker Hub
        run: echo "${{ secrets.DOCKER_PASSWORD }}" | docker login -u "${{ secrets.DOCKER_USERNAME }}" --password-stdin

      - name: Tag imagem
        run: docker tag api-sentimentos ${{ secrets.DOCKER_USERNAME }}/api-sentimentos:latest

      - name: Push imagem
        run: docker push ${{ secrets.DOCKER_USERNAME }}/api-sentimentos:latest
